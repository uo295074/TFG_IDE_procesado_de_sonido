<effects>

  <effect name="Gain">
    <param name="Gain"/>
  </effect>

  <effect name="Distortion">
    <param name="Drive"/>
    <param name="Mix"/>
    <selector name="Mode">
      <option>Soft</option>
      <option>Hard</option>
      <option>Foldback</option>
    </selector>
  </effect>

  <effect name="Filter">
    <param name="Cutoff"/>
    <selector name="Mode">
      <option>Low-pass</option>
      <option>High-pass</option>
      <option>Band-pass</option>
    </selector>
  </effect>

  <effect name="Tremolo">
    <param name="Rate"/>
    <param name="Depth"/>
    <selector name="Wave">
      <option>Sine</option>
      <option>Square</option>
      <option>Triangle</option>
    </selector>
  </effect>

</effects>